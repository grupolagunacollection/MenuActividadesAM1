<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lagoona Bacalar | Curated Vacation Homes</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
    --teal: #0e4a45;
    --teal-light: #1a7a72;
    --gold: #b8955a;
    --gold-light: #d4b57a;
    --sand: #f5f2ed;
    --sand-dark: #e0dcd5;
    --muted: #6b6b6b;
    --white: #ffffff;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body { font-family: 'Jost', sans-serif; background: var(--sand); color: var(--teal); line-height: 1.6; }
h1, h2, h3, h4 { font-family: 'Cormorant Garamond', serif; font-weight: 400; }
img { max-width: 100%; height: auto; display: block; }
a { text-decoration: none; color: inherit; transition: all .25s; }
.container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
.section-intro { text-align: center; margin-bottom: 48px; }
.section-label { font-size: 11px; letter-spacing: .25em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; text-transform: uppercase; }
.section-title { font-size: clamp(32px, 5vw, 48px); margin-bottom: 16px; color: var(--teal); }
.section-desc { font-size: 16px; color: var(--muted); max-width: 700px; margin: 0 auto; line-height: 1.7; }
.reveal { opacity: 0; transform: translateY(20px); transition: all .6s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }

/* NAV */
.navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; background: rgba(14, 74, 69, .95); backdrop-filter: blur(10px); padding: 16px 0; transition: all .3s; }
.nav-inner { display: flex; justify-content: space-between; align-items: center; }
.nav-logo { font-family: 'Cormorant Garamond', serif; font-size: 24px; color: var(--white); letter-spacing: .1em; }
.nav-right { display: flex; align-items: center; gap: 16px; }
.nav-tabs { display: flex; gap: 0; border: 1px solid rgba(184, 149, 90, .25); }
.nav-tab-btn { font-size: 11px; background: transparent; border: none; color: rgba(255, 255, 255, .5); font-family: 'Jost', sans-serif; letter-spacing: .22em; text-transform: uppercase; padding: 9px 16px; cursor: pointer; transition: all .25s; white-space: nowrap; }
.nav-tab-btn.active { background: rgba(184, 149, 90, .15); color: var(--gold-light); }
.nav-tab-btn:hover:not(.active) { color: rgba(255, 255, 255, .8); }
.nav-links { display: flex; gap: 2px; flex-wrap: wrap; }
.nav-links a { color: rgba(255, 255, 255, .55); text-decoration: none; font-size: 10px; letter-spacing: .2em; text-transform: uppercase; padding: 8px 11px; transition: all .25s; }
.nav-links a:hover { color: var(--gold-light); background: rgba(184, 149, 90, .1); }
.nav-reserve { background: var(--gold) !important; color: #fff !important; padding: 8px 16px !important; }
.nav-reserve:hover { background: var(--gold-light) !important; }

/* PAGE VIEWS */
.page-view { display: none; padding-top: 80px; }
.page-view.active { display: block; }

/* HERO */
.welcome-strip { background: var(--teal); padding: 52px 20px; text-align: center; position: relative; overflow: hidden; }
.hero-bg { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(135deg, #0e4a45, #1a7a72); opacity: .1; }
.hero-content { position: relative; z-index: 1; }
.hero-eyebrow { font-size: 11px; letter-spacing: .25em; text-transform: uppercase; color: var(--gold-light); margin-bottom: 12px; }
.hero-brand { font-family: 'Cormorant Garamond', serif; font-size: clamp(42px, 8vw, 64px); color: var(--white); margin-bottom: 16px; }
.hero-sub { font-size: 16px; color: rgba(255, 255, 255, .8); max-width: 600px; margin: 0 auto; }

/* HUB GRID */
.hub-section { padding: 32px 40px 40px; }
.hub-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; max-width: 1200px; margin: 0 auto; }
.hub-card { background: #fff; border-radius: 4px; overflow: hidden; cursor: pointer; transition: transform .25s, box-shadow .25s; box-shadow: 0 2px 12px rgba(26, 74, 74, 0.08); }
.hub-card:hover { transform: translateY(-4px); box-shadow: 0 8px 28px rgba(26, 74, 74, 0.15); }
.hub-photo { height: 140px; position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; }
.hub-photo img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
.hub-card:hover .hub-photo img { transform: scale(1.05); }
.hub-photo-placeholder { display: flex; flex-direction: column; align-items: center; gap: 8px; opacity: .7; }
.hub-photo-placeholder span { font-size: 10px; letter-spacing: .1em; text-transform: uppercase; color: rgba(255, 255, 255, 0.7); }
.hub-info { display: flex; align-items: center; gap: 10px; padding: 14px 16px; background: #fff; }
.hub-icon { font-size: 20px; flex-shrink: 0; }
.hub-name { font-family: 'Jost', sans-serif; font-size: 13px; font-weight: 500; color: var(--teal); letter-spacing: .02em; margin: 0 0 2px; }
.hub-sub { font-size: 11px; color: var(--muted); margin: 0; line-height: 1.3; }
.hub-arrow { margin-left: auto; flex-shrink: 0; color: var(--gold); opacity: .6; }

/* SERVICE PAGE */
.service-page { padding: 48px 40px; max-width: 1200px; margin: 0 auto; }
.service-page-header { margin-bottom: 40px; }
.service-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.service-card { background: #fff; border-radius: 4px; overflow: hidden; box-shadow: 0 2px 12px rgba(26, 74, 74, 0.06); }
.service-card-photo { height: 220px; background: var(--sand-dark); position: relative; overflow: hidden; }
.service-card-photo img { width: 100%; height: 100%; object-fit: cover; }
.service-card-photo-placeholder { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; color: var(--muted); }
.service-card-body { padding: 24px; }
.service-card-icon { font-size: 28px; margin-bottom: 12px; }
.service-card-name { font-family: 'Cormorant Garamond', serif; font-size: 22px; color: var(--teal); margin-bottom: 10px; }
.service-card-desc { font-size: 15px; color: var(--muted); line-height: 1.7; margin-bottom: 16px; }
.service-avail { display: inline-flex; align-items: center; gap: 6px; font-size: 11px; letter-spacing: .12em; text-transform: uppercase; color: var(--gold); font-weight: 400; }
.service-avail::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--gold); flex-shrink: 0; }
.service-wa-btn { display: inline-flex; align-items: center; gap: 8px; background: var(--teal); color: #fff; padding: 10px 20px; font-family: 'Jost', sans-serif; font-size: 12px; letter-spacing: .12em; text-transform: uppercase; text-decoration: none; border: none; cursor: pointer; transition: background .2s; margin-top: 8px; }
.service-wa-btn:hover { background: #2d7a7a; }
.service-coming-soon { background: rgba(184, 149, 90, 0.08); border: 1px solid rgba(184, 149, 90, 0.25); border-radius: 4px; padding: 24px 28px; display: flex; align-items: center; gap: 16px; margin-top: 8px; }
.service-coming-soon svg { flex-shrink: 0; color: var(--gold); opacity: .7; }

/* DELIVERY */
.delivery-grid { display: grid; grid-template-columns: 1fr; gap: 20px; margin-bottom: 32px; }
.delivery-card { background: #fff; border-radius: 4px; padding: 24px 28px; box-shadow: 0 2px 12px rgba(26, 74, 74, 0.07); display: flex; gap: 18px; align-items: flex-start; }
.delivery-card-icon { font-size: 32px; flex-shrink: 0; line-height: 1; }
.delivery-card-name { font-family: 'Jost', sans-serif; font-size: 15px; font-weight: 500; color: var(--teal); margin: 0 0 4px; }
.delivery-card-desc { font-size: 13px; color: var(--muted); line-height: 1.6; margin: 0 0 12px; }
.delivery-wa-link { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; letter-spacing: .1em; text-transform: uppercase; color: var(--gold); text-decoration: none; font-family: 'Jost', sans-serif; }

/* KAYAK & TOURS */
.kayak-feature { background: #fff; border-top: 1px solid var(--sand-dark); border-bottom: 1px solid var(--sand-dark); padding: 76px 20px; }
.kayak-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
.kayak-text .section-label, .kayak-text .section-title { text-align: left; }
.kayak-text p { font-size: 14px; line-height: 1.9; color: var(--muted); margin-bottom: 26px; }
.kayak-prices { display: flex; gap: 12px; flex-wrap: wrap; }
.kayak-price-card { flex: 1; min-width: 110px; border: 1px solid var(--sand-dark); padding: 20px; text-align: center; -webkit-tap-highlight-color: rgba(184, 149, 90, 0.2); }
.kayak-price-card.featured { background: var(--teal); border-color: var(--teal); }
.kp-type { font-size: 10px; letter-spacing: .22em; text-transform: uppercase; color: var(--muted); margin-bottom: 8px; }
.kayak-price-card.featured .kp-type { color: rgba(255, 255, 255, .4); }
.kp-price { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 400; color: var(--teal); }
.kayak-price-card.featured .kp-price { color: var(--gold-light); }
.kp-sub { font-size: 11px; color: var(--muted); margin-top: 4px; }
.kayak-price-card.featured .kp-sub { color: rgba(255, 255, 255, .3); }
.kayak-photo { width: 100%; height: 280px; object-fit: cover; display: block; border-radius: 3px; }
.kayak-reserve { text-align: center; padding: 12px; background: var(--teal); cursor: pointer; transition: all .25s; margin-top: 16px; border-radius: 3px; }
.kayak-reserve p { font-size: 11px; letter-spacing: .15em; text-transform: uppercase; color: var(--gold); margin: 0; }
.kayak-reserve:hover { opacity: 0.85; }

/* TOUR CARDS */
.tour-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; max-width: 1200px; margin: 0 auto; padding: 0 20px 48px; }
.tour-card { background: #fff; border-radius: 4px; overflow: hidden; box-shadow: 0 2px 12px rgba(26, 74, 74, 0.06); }
.tour-photo-wrap { height: 240px; background: var(--sand-dark); position: relative; overflow: hidden; }
.tour-photo { width: 100%; height: 100%; object-fit: cover; }
.tour-body { padding: 24px; }
.tour-number { font-size: 11px; letter-spacing: .2em; color: var(--gold); text-transform: uppercase; margin-bottom: 8px; }
.tour-name { font-family: 'Cormorant Garamond', serif; font-size: 26px; color: var(--teal); margin-bottom: 12px; }
.tour-desc { font-size: 15px; color: var(--muted); line-height: 1.7; margin-bottom: 20px; }
.tour-prices { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px; }
.price-box { border: 1px solid var(--sand-dark); padding: 13px 10px; text-align: center; }
.price-box-label { font-size: 9px; letter-spacing: .2em; text-transform: uppercase; color: var(--muted); margin-bottom: 5px; }
.price-box-amount { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 400; color: var(--teal); }
.price-box-full { grid-column: span 2; border: 1px solid var(--teal); background: var(--teal); padding: 13px 10px; text-align: center; }
.price-box-full .price-box-label { color: rgba(255, 255, 255, .4); }
.price-box-full .price-box-amount { color: var(--gold-light); }
.price-box-sub { font-size: 10px; color: var(--muted); margin-top: 3px; line-height: 1.4; }
.price-box.priv .price-box-sub { color: rgba(255, 255, 255, .3); }
.tour-footer { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding-top: 14px; border-top: 1px solid var(--sand-dark); flex-wrap: wrap; }
.schedule-label { font-size: 9px; letter-spacing: .25em; text-transform: uppercase; color: var(--muted); margin-bottom: 5px; }
.schedule-times { display: flex; gap: 5px; flex-wrap: wrap; }
.time-badge { font-size: 14px; background: var(--teal); color: rgba(255, 255, 255, .85); font-size: 11px; padding: 4px 9px; }
.reserve-btn { background: var(--gold); color: #fff; border: none; cursor: pointer; font-family: 'Jost', sans-serif; font-size: 10px; letter-spacing: .22em; text-transform: uppercase; padding: 10px 16px; font-weight: 400; transition: background .25s; white-space: nowrap; text-decoration: none; display: inline-block; }
.reserve-btn:hover { background: var(--gold-light); }

/* BOOKING */
.booking-section { background: var(--teal); padding: 76px 20px; }
.booking-inner { max-width: 600px; margin: 0 auto; background: #fff; padding: 40px; border-radius: 4px; }
.booking-title { font-family: 'Cormorant Garamond', serif; font-size: 22px; color: var(--teal); margin-bottom: 20px; }
.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
.form-group { margin-bottom: 16px; }
.form-group.full { grid-column: span 1; }
.form-label { display: block; font-size: 11px; letter-spacing: .15em; text-transform: uppercase; color: var(--muted); margin-bottom: 6px; }
.form-input, .form-select, .form-textarea { width: 100%; padding: 12px; border: 1px solid var(--sand-dark); border-radius: 3px; font-family: 'Jost', sans-serif; font-size: 14px; color: var(--teal); }
.form-textarea { resize: vertical; min-height: 100px; }
.form-submit { width: 100%; background: var(--gold); color: #fff; border: none; padding: 14px; font-family: 'Jost', sans-serif; font-size: 11px; letter-spacing: .2em; text-transform: uppercase; cursor: pointer; transition: background .25s; font-weight: 500; }
.form-submit:hover { background: var(--gold-light); }
.form-or { text-align: center; margin: 16px 0; color: var(--muted); font-size: 12px; }
.form-wa { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; background: #25D366; color: #fff; padding: 14px; border-radius: 3px; text-decoration: none; font-family: 'Jost', sans-serif; font-size: 11px; letter-spacing: .2em; text-transform: uppercase; font-weight: 500; transition: background .25s; }
.form-wa:hover { background: #1ebc57; }
.form-note { font-size: 11px; color: var(--muted); text-align: center; margin-top: 12px; }
.form-success { display: none; text-align: center; padding: 40px 20px; }
.form-success-icon { width: 60px; height: 60px; background: var(--teal); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; }
.form-success-icon svg { width: 30px; height: 30px; stroke: #fff; }
.form-success h3 { font-family: 'Cormorant Garamond', serif; font-size: 24px; color: var(--teal); margin-bottom: 12px; }
.form-success p { font-size: 14px; color: var(--muted); line-height: 1.7; margin-bottom: 20px; }

/* PRACTICAL */
.practical { background: #fff; padding: 76px 20px; }
.practical-inner { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
.info-block { background: var(--sand); padding: 32px; border-radius: 4px; }
.info-block-title { font-family: 'Cormorant Garamond', serif; font-size: 20px; color: var(--teal); margin-bottom: 20px; }
.info-item { margin-bottom: 16px; }
.info-item strong { display: block; font-size: 13px; color: var(--teal); margin-bottom: 4px; font-weight: 500; }
.info-item span { font-size: 14px; color: var(--muted); line-height: 1.6; }

/* FOOTER */
.footer-photo-strip { height: 200px; background: url('data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==') center/cover; }
footer { background: var(--teal); color: var(--white); padding: 48px 20px; text-align: center; }
.footer-logo { font-family: 'Cormorant Garamond', serif; font-size: 32px; margin-bottom: 8px; }
.footer-tagline { font-size: 14px; opacity: .8; margin-bottom: 24px; }
.footer-divider { width: 40px; height: 1px; background: var(--gold); margin: 0 auto 24px; }
.footer-wa { display: inline-flex; align-items: center; gap: 8px; background: rgba(255, 255, 255, .1); padding: 10px 20px; border-radius: 3px; color: #fff; text-decoration: none; font-size: 12px; transition: background .25s; }
.footer-wa:hover { background: rgba(255, 255, 255, .2); }
.footer-address { font-size: 12px; opacity: .7; margin-top: 24px; line-height: 1.6; }
.footer-copy { font-size: 11px; opacity: .5; margin-top: 32px; }

/* MOBILE */
@media(max-width: 768px) {
    .hub-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .hub-grid .hub-card:last-child { grid-column: span 2; }
    .kayak-inner { grid-template-columns: 1fr; }
    .kayak-photo { display: none; }
    .kayak-prices { grid-template-columns: 1fr 1fr; }
    .kp-price { font-size: 26px; }
    .tour-grid { grid-template-columns: 1fr; }
    .tour-card { margin-bottom: 24px; }
    .tour-prices { grid-template-columns: 1fr; }
    .price-box-full { grid-column: span 1; }
    .booking-inner { padding: 28px 16px; }
    .form-grid { grid-template-columns: 1fr; }
    .practical-inner { grid-template-columns: 1fr; }
    .nav-links { display: none; }
    .hero-brand { font-size: 44px !important; }
}
@media(max-width: 400px) {
    .hub-grid { grid-template-columns: 1fr; }
    .hub-grid .hub-card:last-child { grid-column: span 1; }
    .route-visual { grid-template-columns: 1fr; }
    .hero-brand { font-size: 44px !important; }
    .nav-links { display: none; }
}
</style>
</head>
<body>

<!-- NAV -->
<nav class="navbar">
    <div class="container nav-inner">
        <a class="nav-logo" href="#" onclick="showPage('tours');return false">LAGOONA</a>
        <div class="nav-right">
            <div class="nav-tabs" id="nav-tab-area">
                <button class="nav-tab-btn active" id="tab-tours" onclick="showPage('tours')" data-i18n="nav.tours">Tours & Actividades</button>
                <button class="nav-tab-btn" id="tab-gastro" onclick="showPage('gastro')" data-i18n="nav.gastro">Gastronomía</button>
                <button class="nav-tab-btn" id="tab-amenidades" onclick="showPage('amenidades')" data-i18n="nav.amenidades">Amenidades</button>
                <button class="nav-tab-btn" id="tab-servicios" onclick="showPage('servicios')" data-i18n="nav.servicios">Servicios</button>
                <button class="nav-tab-btn" id="tab-delivery" onclick="showPage('delivery')" data-i18n="nav.delivery">Delivery</button>
            </div>
            <div class="nav-links" id="nav-tours-links">
                <a href="#tours-section" data-i18n="nav.link.tours">Tours</a>
                <a href="#kayak-section" data-i18n="nav.link.kayak">Kayak</a>
                <a href="#recorrido-section" data-i18n="nav.link.recorrido">Recorrido</a>
                <a href="#reservar" class="nav-reserve" data-i18n="nav.link.reservar">Reservar</a>
            </div>
            <div class="nav-links" id="nav-gastro-links" style="display:none">
                <a href="#gastro-breakfast" onclick="showMoment('breakfast')" data-i18n="nav.link.breakfast">Desayunos</a>
                <a href="#gastro-lunch" onclick="showMoment('lunch')" data-i18n="nav.link.lunch">Comidas</a>
                <a href="#gastro-dinner" onclick="showMoment('dinner')" data-i18n="nav.link.dinner">Cenas</a>
                <a href="#gastro-bars" onclick="showMoment('bars')">Bares</a>
            </div>
        </div>
    </div>
</nav>

<!-- PAGE: TOURS -->
<div class="page-view active" id="page-tours">
    <div class="welcome-strip">
        <div class="hero-bg"></div>
        <div class="hero-content">
            <p class="hero-eyebrow" data-i18n="hero.eyebrow">Aldea Mayab · Bacalar, Quintana Roo</p>
            <h1 class="hero-brand">LAGOONA</h1>
            <p class="hero-sub" data-i18n="hero.sub">Guía de huéspedes · Aldea Mayab</p>
        </div>
    </div>

    <!-- TOURS GRID -->
    <div id="tours-section" class="tour-grid">
        <!-- 01 PADDLE -->
        <div class="tour-card reveal">
            <div class="tour-photo-wrap"><img class="tour-photo" src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==" alt="Paddle Board"></div>
            <div class="tour-body">
                <p class="tour-number">01</p>
                <h3 class="tour-name" data-i18n="tour1.name">Paddle Board</h3>
                <p class="tour-desc" data-i18n="tour1.desc">Deslízate sobre la laguna en una experiencia tranquila y conectada con la naturaleza. Ideal para amaneceres.</p>
                <div class="tour-prices">
                    <div class="price-box"><p class="price-box-label" data-i18n="price.shared">Compartido</p><p class="price-box-amount">$550</p><p class="price-box-sub" data-i18n="price.per_person">MXN por persona</p></div>
                    <div class="price-box priv"><p class="price-box-label" data-i18n="price.private">Privado</p><p class="price-box-amount">$3,000</p><p class="price-box-sub" data-i18n="pax1">1–4 pax · +$400/extra</p></div>
                </div>
                <div class="tour-footer">
                    <div><p class="schedule-label" data-i18n="time.label">Horario</p><div class="schedule-times"><span class="time-badge">8:00</span><span class="time-badge">11:00</span><span class="time-badge">15:00</span></div></div>
                    <button class="reserve-btn" onclick="selectTour('Paddle Board')" data-i18n="btn.reserve">Reservar</button>
                </div>
            </div>
        </div>
        <!-- 02 VELERO -->
        <div class="tour-card reveal">
            <div class="tour-photo-wrap"><img class="tour-photo" src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==" alt="Velero"></div>
            <div class="tour-body">
                <p class="tour-number">02</p>
                <h3 class="tour-name" data-i18n="tour2.name">Velero Privado</h3>
