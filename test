// ── PAGE SWITCHING ──
function showPage(page, skipScroll) {
    document.querySelectorAll('.page-view').forEach(p => p.classList.remove('active'));
    document.getElementById('page-' + page).classList.add('active');
    // Nav tabs
    ['tours','gastro','amenidades','servicios','delivery'].forEach(p => {
        const tab = document.getElementById('tab-' + p);
        if (tab) tab.classList.toggle('active', p === page);
    });
    // Nav links
    document.getElementById('nav-tours-links').style.display = page === 'tours' ? 'flex' : 'none';
    document.getElementById('nav-gastro-links').style.display = page === 'gastro' ? 'flex' : 'none';
    if (!skipScroll) window.scrollTo(0,0);
    setTimeout(triggerReveal,100);
}
// ── GASTRO MOMENT TABS ──
function showMoment(moment) {
    const sections = ['breakfast','lunch','dinner','bars'];
    sections.forEach(s => {
        document.getElementById('gastro-' + s).classList.toggle('active', s === moment);
    });
    document.querySelectorAll('.moment-pill').forEach((p, i) => {
        p.classList.toggle('active', i === sections.indexOf(moment));
    });
    setTimeout(triggerReveal, 100);
}
// ── AUTO-SELECT TOUR + SCROLL TO FORM ──
function selectTour(tour, modalityName) {
    document.getElementById('f-tour').value = tour;
    const modRow = document.getElementById('modalidad-row');
    if(modalityName) {
        modRow.style.display = 'block';
        document.getElementById('f-modalidad').value = modalityName;
    } else {
        modRow.style.display = 'none';
    }
    // Scroll to form
    document.getElementById('reservar').scrollIntoView({ behavior: 'smooth', block: 'start' });
}
// ── WHATSAPP DIRECT (PRIORITIZED) ──
function openWhatsApp() {
    var nombre = document.getElementById('f-nombre').value.trim();
    var edificio = document.getElementById('f-unidad').value.trim();
    var wa = document.getElementById('f-whatsapp').value.trim();
    var tour = document.getElementById('f-tour').value;
    var mod = document.getElementById('f-modalidad').value;
    var fecha = document.getElementById('f-fecha').value;
    var personas = document.getElementById('f-personas').value.trim();
    var notas = document.getElementById('f-notas').value.trim();

    if (!nombre) { alert('Por favor ingresa tu nombre.'); return; }
    if (!tour) { alert('Por favor selecciona un tour.'); return; }
    if (!fecha) { alert('Por favor elige una fecha.'); return; }

    // Build WhatsApp Message
    var waMsg = '🌊 *Nueva Consulta — Aldea Mayab*%0A%0A'+ 
                '*Nombre:* ' + encodeURIComponent(nombre) + '%0A' +
                '*Edificio/Depto:* ' + encodeURIComponent(edificio|| '—') + '%0A' +
                '*WhatsApp:* ' + encodeURIComponent(wa) + '%0A' +
                '*Tour:* ' + encodeURIComponent(tour) + '%0A' +
                '*Modalidad:* ' + encodeURIComponent(mod|| 'N/A') + '%0A' +
                '*Fecha:* ' + encodeURIComponent(fecha) + '%0A' +
                '*Personas:* ' + encodeURIComponent(personas|| '—') + '%0A' +
                '*Notas:* ' + encodeURIComponent(notas|| '—');

    // Open WhatsApp
    window.open('https://wa.me/529842411410?text=' + waMsg, '_blank');
}
// ── SCROLL REVEAL ──
function triggerReveal() {
    const io = new IntersectionObserver((entries) => {
        entries.forEach((e, i) => {
            if (e.isIntersecting) { 
                setTimeout(() => e.target.classList.add('visible'), i * 65); 
                io.unobserve(e.target); 
            }
        });
    }, { threshold: 0.07 });
    document.querySelectorAll('.reveal:not(.visible)').forEach(el => io.observe(el));
}
triggerReveal();

